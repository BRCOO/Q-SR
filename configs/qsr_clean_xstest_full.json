{
  "model_name": "Qwen/Qwen2.5-0.5B-Instruct",
  "precision": "4bit",
  "dataset_csv": "data/xstest/xstest_prompts.csv",
  "router_v6_path": "checkpoints/router_v6/router_v6.joblib",
  "router_v7_path": "checkpoints/router_v7/router_v7.joblib",
  "safety_adapter_path": "checkpoints/safety_lora_v5_hard_templates",
  "factual_adapter_path": "checkpoints/factual_lora_small",
  "threshold": 0.5,
  "max_samples": 0,
  "max_new_tokens": 32,
  "output_path": "results/qsr_clean/xstest_full.json",
  "trust_remote_code": true,
  "use_chat_template": true,
  "use_benign_override": true,
  "use_risk_override": true,
  "use_fixed_high_risk_refusal": true,
  "use_safe_feature_recovery": true,
  "use_utility_safe_override": true,
  "use_harmful_intent_blocker": true,
  "utility_calibrator_path": "checkpoints/utility_calibrator_v5_text_expanded_synth/utility_calibrator.joblib",
  "utility_threshold": 0.35,
  "use_pattern_utility_gate": false,
  "benign_gate_min": 1,
  "safe_recovery_mode": "feature_only",
  "use_semantic_benign_gate": false
}
